    "build:shared": "npm run build --workspace=@letssplyt/shared"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0"
  }
}
