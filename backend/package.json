{
  "name": "letssplyt-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:rls": "jest --testPathPattern=rls",
    "smoke:expenses-reset": "ts-node scripts/smoke-expenses-reset.ts",
    "smoke:receipts-confirm": "ts-node scripts/smoke-receipts-confirm.ts",
    "smoke:splits": "ts-node scripts/smoke-splits.ts",
    "smoke:messages-preview": "ts-node scripts/smoke-messages-preview.ts",
    "cleanup:phone": "ts-node scripts/cleanup-auth-by-phone.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@letssplyt/shared": "1.0.0",
    "@napi-rs/canvas": "^0.1.100",
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/qstash": "^2.7.0",
    "@upstash/redis": "^1.34.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "libphonenumber-js": "^1.11.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.33.0",
    "twilio": "^5.3.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
