APP_ENV=development
APP_URL=http://localhost:3000
APP_DOMAIN=http://localhost:3000
PORT=3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

TWILIO_ACCOUNT_SID=ACtest
TWILIO_AUTH_TOKEN=test-auth-token
TWILIO_PHONE_NUMBER=+15005550006
SMS_PROVIDER=twilio
TELNYX_API_KEY=KEYyour_telnyx_api_key
TELNYX_FROM_NUMBER=+14155550001
# OTP dev bypass is ON by default when APP_ENV=development. Any 6-digit code works; no SMS sent.
# OTP_DEV_BYPASS=true

# Self-generated secrets — lengths are HEX character counts in Doppler.
# openssl rand -hex N prints 2×N hex chars (N random bytes).
# Full reference: docs/09-Security-And-Privacy.md §3
PHONE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# ↑ 64 hex chars (openssl rand -hex 32). NOT 128 chars — wrong length throws EncryptionError on OTP verify.

PII_HMAC_SALT=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# ↑ 64 hex chars (openssl rand -hex 32)

HANDLE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# ↑ 64 hex chars (openssl rand -hex 32)

# JWT_SECRET=...128 hex chars...  # openssl rand -hex 64 — set in Doppler for deployed envs
# ANALYTICS_SALT=...32 hex chars...  # openssl rand -hex 16

# Set A1_DEV_STUB=true in local dev when Gemini quota is exhausted (never in staging/production).
A1_DEV_STUB=false
AI_PROVIDER_A1=gemini
AI_MODEL_A1=gemini-2.5-flash
AI_PROVIDER_A2=gemini
AI_MODEL_A2=gemini-2.5-flash
AI_PROVIDER_A3=gemini
AI_MODEL_A3=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-key
