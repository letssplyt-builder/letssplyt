APP_ENV=development
APP_URL=http://localhost:3000
APP_DOMAIN=http://localhost:3000
PORT=3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

TWILIO_ACCOUNT_SID=ACtest
TWILIO_AUTH_TOKEN=test-auth-token
TWILIO_VERIFY_SERVICE_SID=VAtest
# OTP dev bypass is ON by default when APP_ENV=development (Twilio Verify rejects test creds).
# Any 6-digit code works; no SMS sent. Set false only with TWILIO_USE_LIVE_VERIFY=true + live creds.
# OTP_DEV_BYPASS=true

PHONE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PII_HMAC_SALT=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
HANDLE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

AI_PROVIDER_A1=gemini
AI_MODEL_A1=gemini-2.5-flash
AI_PROVIDER_A2=gemini
AI_MODEL_A2=gemini-2.5-flash
AI_PROVIDER_A3=gemini
AI_MODEL_A3=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-key
