{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@letssplyt/shared/*": ["../shared/types/*"],
      "@letssplyt/shared/paymentHandleValidation": ["../shared/utils/paymentHandleValidation.ts"],
      "@letssplyt/shared/utils/splitCalculator": ["../shared/utils/splitCalculator.ts"],
      "@letssplyt/shared/utils/receiptDiscounts": ["../shared/utils/receiptDiscounts.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"],
  "exclude": ["src/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
